From 3053d590dc60e2b5653147acb8738d551f56a4a1 Mon Sep 17 00:00:00 2001
From: QC <qcseoha@postech.ac.kr>
Date: Fri, 26 Sep 2025 14:23:20 +0000
Subject: [PATCH 1/4] priority compare def & use to unblock, yield

---
 src/threads/thread.c | 14 ++++++++++++--
 src/threads/thread.h |  3 +++
 2 files changed, 15 insertions(+), 2 deletions(-)

diff --git a/src/threads/thread.c b/src/threads/thread.c
index 87f22b8..629f66e 100644
--- a/src/threads/thread.c
+++ b/src/threads/thread.c
@@ -237,7 +237,7 @@ thread_unblock (struct thread *t)
 
   old_level = intr_disable ();
   ASSERT (t->status == THREAD_BLOCKED);
-  list_push_back (&ready_list, &t->elem);
+  list_insert_ordered(&ready_list, &t->elem, thread_cmp_priority, NULL); // modified by qc
   t->status = THREAD_READY;
   intr_set_level (old_level);
 }
@@ -308,7 +308,7 @@ thread_yield (void)
 
   old_level = intr_disable ();
   if (cur != idle_thread) 
-    list_push_back (&ready_list, &cur->elem);
+    list_insert_ordered(&ready_list, &cur->elem, thread_cmp_priority, NULL); // modified bt qc
   cur->status = THREAD_READY;
   schedule ();
   intr_set_level (old_level);
@@ -582,3 +582,13 @@ allocate_tid (void)
 /* Offset of `stack' member within `struct thread'.
    Used by switch.S, which can't figure it out on its own. */
 uint32_t thread_stack_ofs = offsetof (struct thread, stack);
+
+/* def by qc to compare priority of threads */
+/* Return true if thread A has a higher priority than thread B.*/
+bool thread_cmp_priority (struct list_elem* a, struct list_elem* b, void* aux UNUSED)
+{
+  struct thread *thread_A = list_entry(a, struct thread, elem);
+  struct thread *thread_B = list_entry(b, struct thread, elem);
+
+  return thread_A->priority > thread_B->priority;
+}
diff --git a/src/threads/thread.h b/src/threads/thread.h
index 7965c06..726ed53 100644
--- a/src/threads/thread.h
+++ b/src/threads/thread.h
@@ -138,4 +138,7 @@ void thread_set_nice (int);
 int thread_get_recent_cpu (void);
 int thread_get_load_avg (void);
 
+/* def by qc to compare priority of threads */
+/* Return true if thread A has a higher priority than thread B.*/
+bool thread_cmp_priority (struct list_elem* a, struct list_elem* b, void* aux UNUSED); // list_sort or list_insert_ordered will use this func
 #endif /* threads/thread.h */
