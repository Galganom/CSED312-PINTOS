From 406243445755f5e3596dcdffcecbbcb2bc437517 Mon Sep 17 00:00:00 2001
From: QC <qcseoha@postech.ac.kr>
Date: Sat, 27 Sep 2025 06:46:05 +0000
Subject: [PATCH 3/4] def test preemption  & use to thread_unblock,
 thread_set_priority, and sema_up

---
 src/threads/synch.c  |  3 +++
 src/threads/thread.c | 19 +++++++++++++++++++
 src/threads/thread.h | 11 +++++++++--
 3 files changed, 31 insertions(+), 2 deletions(-)

diff --git a/src/threads/synch.c b/src/threads/synch.c
index 303b2a8..63a1586 100644
--- a/src/threads/synch.c
+++ b/src/threads/synch.c
@@ -120,6 +120,9 @@ sema_up (struct semaphore *sema)
   }
   sema->value++;
   intr_set_level (old_level);
+  
+  thread_test_preemption(); // modified bt qc
+  
 }
 
 static void sema_test_helper (void *sema_);
diff --git a/src/threads/thread.c b/src/threads/thread.c
index 629f66e..3fcb1a4 100644
--- a/src/threads/thread.c
+++ b/src/threads/thread.c
@@ -240,6 +240,9 @@ thread_unblock (struct thread *t)
   list_insert_ordered(&ready_list, &t->elem, thread_cmp_priority, NULL); // modified by qc
   t->status = THREAD_READY;
   intr_set_level (old_level);
+
+  thread_test_preemption(); // modified bt qc
+  
 }
 
 /* Returns the name of the running thread. */
@@ -336,6 +339,9 @@ void
 thread_set_priority (int new_priority) 
 {
   thread_current ()->priority = new_priority;
+
+  thread_test_preemption(); // modified bt qc
+  
 }
 
 /* Returns the current thread's priority. */
@@ -592,3 +598,16 @@ bool thread_cmp_priority (struct list_elem* a, struct list_elem* b, void* aux UN
 
   return thread_A->priority > thread_B->priority;
 }
+
+/* def by qc, Tests if preemption should occur, causing the current thread to yield.*/
+void thread_test_preemption (void){
+
+  if(!list_empty(&ready_list) && thread_get_priority() < list_entry (list_front (&ready_list), struct thread, elem)->priority)
+  {
+    if (intr_context ()) {
+      intr_yield_on_return ();
+    } else {
+      thread_yield ();
+    }
+  }
+}
\ No newline at end of file
diff --git a/src/threads/thread.h b/src/threads/thread.h
index 726ed53..d3784c1 100644
--- a/src/threads/thread.h
+++ b/src/threads/thread.h
@@ -138,7 +138,14 @@ void thread_set_nice (int);
 int thread_get_recent_cpu (void);
 int thread_get_load_avg (void);
 
-/* def by qc to compare priority of threads */
+/* def by qc to compare priority of threads. */
 /* Return true if thread A has a higher priority than thread B.*/
-bool thread_cmp_priority (struct list_elem* a, struct list_elem* b, void* aux UNUSED); // list_sort or list_insert_ordered will use this func
+bool thread_cmp_priority (struct list_elem* a, struct list_elem* b, void* aux UNUSED); // list_sort or list_insert_ordered will use this func.
+
+/* def by qc, Tests if preemption should occur, causing the current thread to yield.*/
+void thread_test_preemption (void); // Called by thread_unblock, thread_set_priority, and sema_up.
+                                    // NOTE: thread_create calls thread_unblock.
+                                    // NOTE: lock_release calls sema_up.
+                                    // Warn: sema_up() is callable from interrupt. Must be careful yielding.
+
 #endif /* threads/thread.h */
-- 
